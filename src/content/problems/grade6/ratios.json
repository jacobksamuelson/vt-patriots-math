{
  "concept": "ratios",
  "domain": "ratios-proportions",
  "grade": 6,
  "levels": [
    {
      "level": 1,
      "description": "Simplify ratios",
      "templates": [
        {
          "id": "rat-6-1a",
          "question": "Simplify: {product_a}:{product_b} — first number?",
          "variables": {
            "a": { "min": 1, "max": 3 },
            "b": { "min": 4, "max": 7 },
            "m": { "min": 2, "max": 6 }
          },
          "derived": {
            "product_a": "{a} * {m}",
            "product_b": "{b} * {m}"
          },
          "answer": "{a}",
          "hints": [
            "Find a number that divides both {product_a} and {product_b}.",
            "Both are divisible by {m}. {product_a} ÷ {m} = ?"
          ],
          "commonMistakes": [
            "{b}",
            "{m}",
            "{a} + 1"
          ]
        }
      ]
    },
    {
      "level": 2,
      "description": "Solve proportions",
      "templates": [
        {
          "id": "rat-6-2a",
          "question": "{a}/{b} = {c}/? — find the missing number",
          "variables": {
            "a": { "min": 1, "max": 5 },
            "b": { "min": 2, "max": 6 },
            "m": { "min": 2, "max": 5 }
          },
          "derived": {
            "c": "{a} * {m}"
          },
          "answer": "{b} * {m}",
          "hints": [
            "The top was multiplied by {m}. Do the same to the bottom.",
            "{b} × {m} = ?"
          ],
          "commonMistakes": [
            "{b} + {m}",
            "{b} * {m} + 1",
            "{a} * {m}"
          ]
        }
      ]
    }
  ]
}
